# Copy thành file `.env` rồi điền giá trị. Không commit `.env`.

EXPO_PUBLIC_FIRECRAWL_API_KEY=

# URL trang giá (markdown). Để trống = không crawl loại đó.
EXPO_PUBLIC_PRICE_URL_FUEL=
EXPO_PUBLIC_PRICE_URL_GOLD=

# Petrolimex bảng hai cột: 1 = Vùng 1, 2 = Vùng 2 (giá cao hơn vài trăm đ/L).
EXPO_PUBLIC_FUEL_PRICE_REGION=1

# Supabase public client config.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
